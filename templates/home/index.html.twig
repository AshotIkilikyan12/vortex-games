{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }} | Vortex Games{% endblock %}

{% block body %}
<div class="container my-5">
    
    {# HERO SECTION #}
    <div class="text-center mb-5 hero-section">
        <h1 class="gaming-title">VORTEX GAMES</h1>
        <p class="gaming-subtitle">// {{ 'home.hero_subtitle'|trans }}</p>
        <div class="neon-divider"></div>
    </div>

    {# ԴԻՆԱՄԻԿ ՍԼԱՅԴԵՐ (CAROUSEL) #}
    {% if games|length > 0 %}
        <div id="vortexCarousel" class="carousel slide mb-5 gaming-card" data-bs-ride="carousel" style="border: 1px solid rgba(0, 240, 255, 0.25);">
            <div class="carousel-indicators">
                {% for game in games|slice(0, 3) %}
                    <button type="button" data-bs-target="#vortexCarousel" data-bs-slide-to="{{ loop.index0 }}" class="{{ loop.first ? 'active' : '' }}" aria-current="{{ loop.first ? 'true' : 'false' }}"></button>
                {% endfor %}
            </div>
            <div class="carousel-inner">
                {% for game in games|slice(0, 3) %}
                    <div class="carousel-item {{ loop.first ? 'active' : '' }}" style="height: 400px; background: #050811;">
                        {% if game.image %}
                            <img src="{{ asset('uploads/games/' ~ game.image) }}" class="d-block w-100 h-100" alt="{{ game.title }}" style="object-fit: cover; opacity: 0.4; filter: grayscale(20%);">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted" style="background: #0d111c;">
                                <h3>[ NO_IMAGE ]</h3>
                            </div>
                        {% endif %}
                        <div class="carousel-caption d-none d-md-block text-start" style="bottom: 40px; left: 40px; text-shadow: 0 2px 10px rgba(0,0,0,0.9);">
                            <span class="badge bg-success mb-2" style="font-family: monospace; letter-spacing: 1px;">🔥 {{ 'home.trending'|trans }}</span>
                            <h2 class="text-white text-uppercase fw-bold mb-2" style="letter-spacing: 2px;">{{ game.title }}</h2>
                            <p class="text-light mb-3" style="max-width: 600px;">{{ game.description|striptags|slice(0, 120) }}...</p>
                            <a href="{{ path('app_game_show', {id: game.id}) }}" class="gaming-btn text-decoration-none">{{ 'home.more'|trans }}</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#vortexCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">{{ 'home.previous'|trans }}</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#vortexCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">{{ 'home.next'|trans }}</span>
            </button>
        </div>
    {% endif %}

    <div class="row">
        {# ՁԱԽ ԿՈՂՄԱՅԻՆ ՎԱՀԱՆԱԿ (SIDEBAR) #}
        <div class="col-lg-3 col-md-4 mb-5">
            <div class="d-flex flex-column h-100 justify-content-between">
                <div>
                    {# 1. Օգտատիրոջ կարգավիճակ #}
                    {% if app.user %}
                        <div class="mb-4 pb-3 border-bottom border-secondary">
                            <span class="gaming-form-label d-block mb-1" style="font-size: 0.75rem;">{{ 'home.logged_in_as'|trans }}</span>
                            <h6 class="text-white text-truncate m-0">{{ app.user.userIdentifier }}</h6>
                            <a href="{{ path('app_library') }}" class="d-inline-block mt-2 text-decoration-none" style="color: #00ff88; font-size: 0.85rem;">
                                ⚙️ {{ 'navbar.library'|trans }} ({{ app.user.games|length }})
                            </a>
                        </div>
                    {% else %}
                        <div class="mb-4 pb-3 border-bottom border-secondary text-center">
                            <p class="text-muted small mb-3">{{ 'home.login_prompt'|trans }}</p>
                            <a href="{{ path('app_login') }}" class="gaming-btn d-block w-100 py-2 text-center text-decoration-none">{{ 'navbar.login'|trans }}</a>
                        </div>
                    {% endif %}

                    {# 2. Որոնման բաժին #}
                    <div class="mb-4">
                        <label class="gaming-form-label mb-2">{{ 'home.search_game'|trans }}</label>
                        <input type="text" id="gameSearch" class="form-control gaming-input py-2" placeholder="{{ 'home.search_placeholder'|trans }}" style="font-size: 0.85rem;">
                    </div>

                    {# 3. Ֆիլտրերի բաժին #}
                    <div class="mb-4">
                        <label class="gaming-form-label mb-2">{{ 'home.filter_by_price'|trans }}</label>
                        <div class="d-flex flex-column gap-2">
                            <button class="gaming-btn w-100 py-2 filter-btn text-start active-filter" data-filter="all">
                                ⚡️ {{ 'home.filter_all'|trans }}
                            </button>
                            <button class="gaming-btn w-100 py-2 filter-btn text-start" data-filter="free">
                                🆓 {{ 'game.free'|trans }}
                            </button>
                            <button class="gaming-btn w-100 py-2 filter-btn text-start" data-filter="paid">
                                💎 {{ 'home.filter_paid'|trans }}
                            </button>
                        </div>
                    </div>
                </div>

                {# 4. Vortex Համակարգային Ստատուս #}
                <div class="pt-3 border-top border-secondary text-center mt-auto">
                    <span class="badge bg-dark border border-success text-success py-2 px-3 w-100" style="font-family: monospace; letter-spacing: 1px;">
                        ● SYSTEM ONLINE
                    </span>
                </div>
            </div>
        </div>

        {# ԱՋ ԿՈՂՄ (ԽԱՂԵՐԻ ՑՈՒՑԱԿԸ) #}
        <div class="col-lg-9 col-md-8 ps-lg-5">
            <div class="row g-4" id="gamesContainer">
                {% for game in games %}
                    <div class="col-lg-4 col-md-6 game-item-card" data-title="{{ game.title|lower }}" data-price="{{ game.price }}">
                        <div class="card h-100 gaming-card d-flex flex-column justify-content-between">
                            
                            {# Խաղի նկարը #}
                            {% if game.image %}
                                <img src="{{ asset('uploads/games/' ~ game.image) }}" class="card-img-top gaming-card-img" alt="{{ game.title }}" style="object-fit: cover; height: 200px;">
                            {% else %}
                                <div class="d-flex align-items-center justify-content-center gaming-card-img text-muted" style="background-color: #121826; font-family: monospace; height: 200px;">
                                    [ NO_IMAGE ]
                                </div>
                            {% endif %}

                            {# Քարտի տեքստային բաժինը #}
                            <div class="card-body d-flex flex-column justify-content-between p-4 flex-grow-1">
                                <div>
                                    <h5 class="card-title text-uppercase text-truncate mb-2" title="{{ game.title }}">{{ game.title }}</h5>
                                    <p class="card-text game-card-desc mb-3 small text-muted">
                                        {{ game.description|striptags|slice(0, 70) }}...
                                    </p>
                                </div>
                            </div>

                            {# Քարտի ներքևի բաժինը #}
                            <div class="card-footer d-flex align-items-center justify-content-between p-4 border-top border-secondary">
                                <span class="gaming-price fw-bold">
                                    {% if game.price == 0 %}
                                        {{ 'game.free'|trans }}
                                    {% else %}
                                        {{ game.price }} {{ 'home.currency'|trans }}
                                    {% endif %}
                                </span>
                                <a href="{{ path('app_game_show', {id: game.id}) }}" class="gaming-btn text-decoration-none px-3 py-2">
                                    {{ 'home.more'|trans }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center no-games-alert py-5">
                        <p class="fs-4 mb-0 text-muted">{{ 'home.no_games_found'|trans }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# ԻՆՏԵՐԱԿՏԻՎ ՈՐՈՆՈՒՄ ԵՎ ՖԻԼՏՐԱՑՈՒՄ (JAVASCRIPT) #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('gameSearch');
    const filterButtons = document.querySelectorAll('.filter-btn');
    const gameCards = document.querySelectorAll('.game-item-card');

    let activeFilter = 'all';
    let searchQuery = '';

    function applyFilters() {
        gameCards.forEach(card => {
            const title = card.getAttribute('data-title');
            const price = parseFloat(card.getAttribute('data-price'));
            
            const matchesSearch = title.includes(searchQuery);
            let matchesFilter = false;

            if (activeFilter === 'all') {
                matchesFilter = true;
            } else if (activeFilter === 'free') {
                matchesFilter = (price === 0);
            } else if (activeFilter === 'paid') {
                matchesFilter = (price > 0);
            }

            if (matchesSearch && matchesFilter) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    // Որոնման ունկնդրում
    searchInput.addEventListener('input', function(e) {
        searchQuery = e.target.value.toLowerCase();
        applyFilters();
    });

    // Ֆիլտրի կոճակների ունկնդրում
    filterButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            filterButtons.forEach(b => b.classList.remove('active-filter'));
            this.classList.add('active-filter');
            
            activeFilter = this.getAttribute('data-filter');
            applyFilters();
        });
    });
});
</script>
{% endblock %}